# Server Configuration
PORT=4000
NODE_ENV=development

# Database (Supabase PostgreSQL)
# Replace with your actual Supabase connection string
# Format: postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres.hrousezcjlqxtkumspri:Vn8Wn8gM5pn9yzYz@aws-0-us-west-2.pooler.supabase.com:6543/postgres

# Supabase
# Get these from: https://app.supabase.com/project/[YOUR-PROJECT]/settings/api
SUPABASE_URL=https://hrousezcjlqxtkumspri.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Email (SMTP / SendGrid)
# Get your SendGrid API key from: https://app.sendgrid.com/settings/api_keys
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key-here
EMAIL_FROM=noreply@your-domain.com

# Koru Platform
KORU_API_URL=https://www.korusuite.com
KORU_APP_ID=your-koru-app-id-here
KORU_APP_SECRET=your-koru-app-secret-here

# CORS (comma-separated list of allowed origins)
CORS_ORIGIN=http://localhost:3001,http://localhost:3000

# Admin Notification Email
ADMIN_EMAIL=admin@your-domain.com
